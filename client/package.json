{
  "name": "tindai",
  "version": "1.0.0",
  "private": true,
  "main": "expo/AppEntry",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "dev-client": "powershell -ExecutionPolicy Bypass -File ./scripts/dev-client.ps1",
    "dev-client:install": "powershell -ExecutionPolicy Bypass -File ./scripts/dev-client.ps1 -InstallOnly",
    "dev-client:start": "powershell -ExecutionPolicy Bypass -File ./scripts/dev-client.ps1 -StartOnly",
    "dev-client:start:noclear": "powershell -ExecutionPolicy Bypass -File ./scripts/dev-client.ps1 -StartOnly -NoClear",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@expo/vector-icons": "^14.0.4",
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@react-native-google-signin/google-signin": "^16.1.2",
    "@react-native-ml-kit/text-recognition": "^2.0.0",
    "@react-navigation/bottom-tabs": "^7.3.12",
    "@react-navigation/native": "^7.1.7",
    "@shopify/react-native-skia": "2.1.0",
    "@supabase/supabase-js": "^2.57.4",
    "expo": "~53.0.0",
    "expo-asset": "~11.1.7",
    "expo-auth-session": "~6.2.1",
    "expo-crypto": "~14.1.5",
    "expo-dev-client": "~5.2.4",
    "expo-font": "~13.3.2",
    "expo-linear-gradient": "~14.1.5",
    "expo-linking": "^55.0.14",
    "expo-network": "~7.1.5",
    "expo-speech": "~13.1.7",
    "expo-speech-recognition": "^3.1.3",
    "expo-sqlite": "~15.2.14",
    "expo-status-bar": "~2.2.3",
    "expo-web-browser": "~14.2.0",
    "react": "19.0.0",
    "react-native": "0.79.2",
    "react-native-fs": "^2.20.0",
    "react-native-gesture-handler": "~2.24.0",
    "react-native-image-picker": "^8.2.1",
    "react-native-image-resizer": "^1.4.5",
    "react-native-nitro-image": "^0.13.1",
    "react-native-nitro-modules": "^0.35.5",
    "react-native-reanimated": "~3.17.4",
    "react-native-safe-area-context": "5.4.0",
    "react-native-screens": "~4.11.1",
    "react-native-url-polyfill": "^2.0.0",
    "react-native-vision-camera": "^4.6.4",
    "victory-native": "^41.20.2"
