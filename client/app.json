{
  "expo": {
    "name": "tindai",
    "slug": "tindai",
    "scheme": "tindai",
    "version": "1.0.0",
    "icon": "./src/assets/tindai-logo.png",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "jsEngine": "hermes",
    "splash": {
      "image": "./src/assets/tindai-logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "updates": {
      "enabled": false,
      "checkAutomatically": "NEVER",
      "fallbackToCacheTimeout": 0
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSSpeechRecognitionUsageDescription": "Allow Tindai to use speech recognition for voice commands.",
        "NSMicrophoneUsageDescription": "Allow Tindai to use the microphone for voice commands."
      }
    },
    "android": {
      "package": "com.example.tindai",
      "adaptiveIcon": {
        "foregroundImage": "./src/assets/tindai-logo.png",
        "backgroundColor": "#ffffff"
      },
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "bundler": "metro",
      "favicon": "./src/assets/tindai-logo.png"
    },
    "plugins": [
      "expo-dev-client",
      "expo-asset",
      "expo-sqlite",
      "@react-native-google-signin/google-signin",
      [
        "expo-speech-recognition",
        {
          "microphonePermission": "Allow Tindai to use the microphone for voice commands.",
          "speechRecognitionPermission": "Allow Tindai to use speech recognition for voice commands."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "2dc9c32b-59ae-4e9a-b3a5-96d090a5cbad"
      }
    },
    "owner": "snplmntn"
  }
}
