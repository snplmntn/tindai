{
  "expo": {
    "name": "tindai",
    "slug": "tindai",
    "scheme": "tindai",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "jsEngine": "hermes",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.example.tindai"
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": ["expo-asset", "expo-sqlite"]
  }
}
